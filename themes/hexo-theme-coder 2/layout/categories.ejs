<div class="hd logodiv">
    <%- image_tag(theme.gender,{class: 'logopng', alt: 'logo'}) %>
    <p class="logot home-hero-title">
         <%= theme.logo_title %>
         <span class="logo_2"></span>
        <h3 class="words home-hero-subtitle">
            <%= theme.words %>
        </h3>
    </p>
</div>

<%- partial('_partial/nav') %>

<%
    var topCategories = [];
    var topCategoryMap = {};
    var uncategorizedPath = url_for(config.category_dir + '/' + config.default_category + '/');

    site.posts.sort('date', -1).each(function (post) {
        var categories = post.categories && typeof post.categories.toArray === 'function'
            ? post.categories.toArray()
            : [];

        if (!categories.length) {
            categories = [{
                name: '未分类',
                path: uncategorizedPath
            }];
        }

        var topCategory = categories[0];
        var topKey = topCategory.path || topCategory.name;
        var topPath = topCategory.path ? url_for(topCategory.path) : uncategorizedPath;

        if (!topCategoryMap[topKey]) {
            topCategoryMap[topKey] = {
                title: topCategory.name,
                path: topPath,
                count: 0,
                posts: [],
                children: [],
                childMap: {}
            };
            topCategories.push(topCategoryMap[topKey]);
        }

        var group = topCategoryMap[topKey];
        group.count += 1;
        group.posts.push(post);

        if (categories.length === 1) {
            return;
        }

        var childCategories = categories.slice(1);
        var childTitle = childCategories.map(function (category) {
            return category.name;
        }).join(' / ');
        var childPath = url_for(categories[categories.length - 1].path);
        var childKey = categories[categories.length - 1].path;

        if (!group.childMap[childKey]) {
            group.childMap[childKey] = {
                title: childTitle,
                path: childPath,
                count: 0
            };
            group.children.push(group.childMap[childKey]);
        }

        group.childMap[childKey].count += 1;
    });

    topCategories.sort(function (left, right) {
        return right.count - left.count;
    });
%>

<div class="hd categories-page">
    <header class="categories-header">
        <p class="categories-eyebrow">CATEGORY INDEX</p>
        <h1 class="categories-title">按主题浏览</h1>
        <p class="categories-description">
            共 <%= topCategories.length %> 个分类，选择一个方向继续阅读。
        </p>
    </header>

    <div class="categories-grid">
        <% topCategories.forEach(function (category) { %>
            <article class="category-card">
                <header class="category-card-header">
                    <a class="category-card-title" href="<%- category.path %>">
                        <span class="category-card-mark">#</span>
                        <span><%= category.title %></span>
                    </a>
                    <span class="category-card-count"><%= category.count %> 篇</span>
                </header>

                <% if (category.children.length) { %>
                    <div class="category-card-children" aria-label="<%= category.title %> 的子分类">
                        <% category.children.forEach(function (child) { %>
                            <a class="category-card-child" href="<%- child.path %>">
                                <%= child.title %>
                                <span><%= child.count %></span>
                            </a>
                        <% }) %>
                    </div>
                <% } %>

                <div class="category-card-posts">
                    <% category.posts.slice(0, 5).forEach(function (post) { %>
                        <a class="category-card-post" href="<%- url_for(post.path) %>">
                            <span class="category-card-post-title"><%= post.title %></span>
                            <time class="category-card-post-date" datetime="<%= full_date(post.date, 'YYYY-MM-DD') %>">
                                <%- full_date(post.date, 'MM-DD') %>
                            </time>
                        </a>
                    <% }) %>
                </div>

                <a class="category-card-more" href="<%- category.path %>">
                    查看全部 <%= category.count %> 篇
                    <span aria-hidden="true">→</span>
                </a>
            </article>
        <% }) %>
    </div>
</div>
