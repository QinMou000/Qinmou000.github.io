<div class="hd logodiv">
    <%- image_tag(theme.gender,{class: 'logopng', alt: 'logo'}) %>
    <p class="logot">
         <%= theme.logo_title %>
         <span class="logo_2"></span>
        <h3 class="words" style="font-weight: bold;font-family: Georgia;">
            <%= theme.words %>
        </h3>
    </p>
</div>

<%- partial('_partial/nav') %>

<%
    var categoryGroups = [];
    var categoryGroupMap = {};

    site.posts.sort('date', -1).each(function (post) {
        var categories = post.categories && typeof post.categories.toArray === 'function'
            ? post.categories.toArray()
            : [];
        var categoryNames = categories.map(function (category) {
            return category.name;
        });
        var categoryTitle = categoryNames.join(' / ') || '未分类';
        var categoryPath = categories.length
            ? url_for(categories[categories.length - 1].path)
            : url_for(config.category_dir + '/' + config.default_category + '/');

        if (!categoryGroupMap[categoryTitle]) {
            categoryGroupMap[categoryTitle] = {
                title: categoryTitle,
                path: categoryPath,
                posts: []
            };
            categoryGroups.push(categoryGroupMap[categoryTitle]);
        }

        categoryGroupMap[categoryTitle].posts.push(post);
    });
%>

<div class="hd categories-page">
    <% categoryGroups.forEach(function (group) { %>
        <div class="category-group">
            <div class="titlex">
                <p>
                    <a class="category-group-link" href="<%- group.path %>">
                        <span class="jing"># </span><%= group.title %>
                        <span class="category-group-count">（<%= group.posts.length %> 篇）</span>
                    </a>
                </p>
            </div>
            <% group.posts.forEach(function (post) { %>
                <a class="flink" href="<%- url_for(post.path) %>">
                    <div class="list">
                        <div class="postname">
                            <%= post.title %>
                        </div>
                        <div class="posttime">
                            <%- full_date(post.date, 'MMMM Do') %>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% }) %>
</div>
