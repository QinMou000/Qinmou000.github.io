<%
    var pageTitle = page.title
        ? page.title + ' | ' + config.title
        : config.title;
    var pageDescription = page.description || theme.description;
    var pageKeywords = page.keywords || theme.keywords;
%>
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="renderer" content="webkit">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="google-site-verification" content="TZE0rZyIqLl10trYu3BWBWa1Vmz6HFwhb2OcNEK4u-s" />
    <link rel="shortcut icon" href="<%= theme.favicon %>">
    <title><%= pageTitle %></title>
    <meta name="description" content="<%- pageDescription %>">
    <meta name="keywords" content="<%- pageKeywords %>">
    <%- css('libs/highlight/styles/monokai-sublime.css') %>
    <%- css('libs/font-awesome/css/font-awesome.min.css') %>
    <%- css('css/style.css') %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNHUEE2H5uTJM4GnIDq3mF5T0hRJjUB1pMn6WjU/rJ1FhE8p5o2kAItJ" crossorigin="anonymous">
</head>