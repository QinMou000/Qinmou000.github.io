<div class="hd home-hero logodiv">
    <div class="home-hero-avatar">
        <%- image_tag(theme.gender,{class: 'logopng', alt: 'logo'}) %>
    </div>
    <div class="home-hero-copy">
        <p class="logot home-hero-title">
             <%= theme.logo_title %>
             <span class="logo_2"></span>
        </p>
        <p class="words home-hero-subtitle">
            <%= theme.words %>
        </p>
    </div>
</div>

<%- partial('_partial/nav') %>

<div class="hd home-index">
    <div class="home-posts-panel" data-home-posts-panel data-page-size="24">
        <% var uncategorizedKey = '未分类'; %>
        <% var last; %>
        <% var hasOpenYearSection = false; %>
        <% page.posts.each(function (post, index) { %>
            <%
                var categories = post.categories && typeof post.categories.toArray === 'function'
                    ? post.categories.toArray()
                    : [];
                var topCategory = categories.length ? categories[0].name : uncategorizedKey;
                var year = post.date.year();
            %>
            <% if (last != year) { %>
                <% if (hasOpenYearSection) { %>
                    </div>
                <% } %>
                <section class="home-year-group" data-home-year-group data-year="<%= year %>">
                    <div class="titlex home-year-title">
                        <p><span class="home-year-line"></span><span><%= year %></span></p>
                    </div>
                    <div class="home-year-posts">
                <% last = year; %>
                <% hasOpenYearSection = true; %>
            <% } %>
            <a class="flink home-post-link" href="<%- url_for(post.path) %>" data-home-post>
                <div class="list home-post-item">
                    <div class="postname home-post-name">
                        <%= post.title %>
                    </div>
                    <div class="posttime home-post-time">
                        <span class="home-post-category"><%= topCategory %></span>
                        <span class="home-post-time-separator">·</span>
                        <%- full_date(post.date, 'MMM DD') %>
                    </div>
                    <div class="clear"></div>
                </div>
            </a>
            <% if (index === page.posts.length - 1 && hasOpenYearSection) { %>
                    </div>
                </section>
            <% } %>
        <% }) %>
    </div>

    <div class="home-load-more-shell">
        <button class="home-load-more" type="button" data-home-load-more>
            加载更多
        </button>
        <p class="home-result-summary" data-home-result-summary></p>
    </div>
</div>

<script>
    (function () {
        var panel = document.querySelector('[data-home-posts-panel]');
        var loadMoreButton = document.querySelector('[data-home-load-more]');
        var resultSummary = document.querySelector('[data-home-result-summary]');

        if (!panel || !loadMoreButton || !resultSummary) {
            return;
        }

        var posts = Array.prototype.slice.call(document.querySelectorAll('[data-home-post]'));
        var groups = Array.prototype.slice.call(document.querySelectorAll('[data-home-year-group]'));
        var pageSize = Number(panel.getAttribute('data-page-size')) || 24;
        var visibleLimit = pageSize;

        function updateGroups() {
            groups.forEach(function (group) {
                var hasVisiblePost = Array.prototype.some.call(
                    group.querySelectorAll('[data-home-post]'),
                    function (post) {
                        return !post.hidden;
                    }
                );
                group.hidden = !hasVisiblePost;
            });
        }

        function renderPosts() {
            var shownCount = 0;

            posts.forEach(function (post) {
                var shouldShow = shownCount < visibleLimit;
                post.hidden = !shouldShow;

                if (shouldShow) {
                    shownCount += 1;
                }
            });

            updateGroups();
            loadMoreButton.hidden = shownCount >= posts.length;
            resultSummary.textContent = '已显示 ' + shownCount + ' / ' + posts.length + ' 篇';
        }

        loadMoreButton.addEventListener('click', function () {
            visibleLimit += pageSize;
            renderPosts();
        });

        renderPosts();
    })();
</script>
