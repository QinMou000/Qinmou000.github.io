.logodiv {
    text-align: center;
}

.titlex {
    font-size: 30px;
    font-weight: bold;
    margin-top: 30px;
}

.list {
    font-size: 17px;
    padding-left: 25px;
    padding-right: 25px;
    height: 30px;
    cursor: pointer;
}

.postname {
    float: left;
}

.posttime {
    float: right;
}

.logopng {
    width: 150px;
}

.breadcrumb {
    padding: 8px 15px;
    list-style: none;
    background-color: initial;
    border-radius: 0px;
    text-align: center;
}


.jing {
    color: #1E90FF;
}

.logot {
    font-weight: bold;
    font-size: 45px;
    margin-top: 10px;
    margin-bottom: -20px;
}

.logot .logo_1{
    color: #888888;
}

.logot .logo_2{
    color: #37dd2c;
}

.logot .logo_3{
    color: #be8355;
}
.words {
    padding-top: 16px;
    font-size: 20px;
}
.navd {
    padding-top: 14px;
}

.headt {
    border-bottom: 1px solid #efefef;
    height: 50px;
}

.fh {
    top: 24px;
    position: absolute;
}

hr{
    border-color: #58606b;
}

.home-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 56px 0 18px;
}

.home-hero-avatar {
    width: 96px;
    height: 96px;
}

.home-hero .logopng {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 1px solid #232938;
    padding: 6px;
    background-color: #151922;
}

.home-hero-copy {
    max-width: 640px;
}

.home-hero-title {
    margin: 0;
    font-size: 42px;
    line-height: 1.2;
    letter-spacing: 0.04em;
}

.home-hero-subtitle {
    margin: 14px 0 0;
    padding-top: 0;
    font-size: 16px;
    line-height: 1.9;
    color: #99a3b8;
}

.home-index {
    padding-bottom: 24px;
}

.home-layout,
.home-layout-shell,
.home-index-layout {
    display: grid;
    grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
}

.home-layout-sidebar,
.home-category-sidebar {
    position: sticky;
    top: 18px;
}

.home-layout-content,
.home-posts,
.home-posts-panel {
    min-width: 0;
}

.home-category-card,
.home-category-sidebar {
    padding: 18px;
    border: 1px solid #232938;
    border-radius: 18px;
    background-color: #151922;
}

.home-category-nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.home-category-title p {
    display: flex;
    align-items: center;
    margin: 0;
}

.home-category-heading,
.home-category-title {
    margin: 0 0 14px;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8f9bb3;
}

.home-category-list,
.home-category-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.home-category-link,
.home-category-button,
.home-category-item > a,
.home-category-item > button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    padding: 10px 14px;
    border: 1px solid transparent;
    border-radius: 12px;
    background-color: transparent;
    color: #c8d1e3;
    font-size: 14px;
    line-height: 1.5;
    text-align: left;
}

.home-category-link:hover,
.home-category-button:hover,
.home-category-item > a:hover,
.home-category-item > button:hover {
    color: #ffffff;
    border-color: #323a4c;
    background-color: #1a2030;
    transform: translateX(2px);
}

.home-category-link.is-active,
.home-category-link.active,
.home-category-button.is-active,
.home-category-button.active,
.home-category-item.is-active > a,
.home-category-item.active > a,
.home-category-item.is-active > button,
.home-category-item.active > button {
    color: #eef2ff;
    border-color: #8aa4ff;
    background-color: rgba(138, 164, 255, 0.12);
    box-shadow: inset 0 0 0 1px rgba(138, 164, 255, 0.12);
}

.home-category-name,
.home-category-label {
    min-width: 0;
    flex: 1;
}

.home-category-count,
.home-category-badge {
    flex-shrink: 0;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: #8f9bb3;
}

.home-posts-empty,
.home-empty {
    padding: 40px 24px;
    border: 1px dashed #323a4c;
    border-radius: 18px;
    color: #8f9bb3;
    background-color: rgba(21, 25, 34, 0.72);
    text-align: center;
}

.home-posts-empty p,
.home-empty p {
    margin: 0;
}

.home-year-title {
    margin-top: 44px;
    margin-bottom: 16px;
    font-size: 26px;
}

.home-year-title:first-child {
    margin-top: 0;
}

.home-year-title p {
    display: flex;
    align-items: center;
    margin: 0;
    color: #eef2ff;
}

.home-year-line {
    display: inline-block;
    width: 38px;
    height: 1px;
    margin-right: 14px;
    background-color: #8aa4ff;
}

.home-post-link {
    display: block;
}

.home-post-item {
    height: auto;
    min-height: 0;
    padding: 16px 2px;
    border-bottom: 1px solid #232938;
}

.home-post-link:hover .home-post-item {
    border-color: #323a4c;
    transform: translateX(2px);
}

.home-post-name {
    max-width: calc(100% - 120px);
    font-size: 17px;
    color: #e7ebf5;
}

.home-post-time {
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #778198;
}

.bg_while .home-hero .logopng {
    background-color: #ffffff;
    border-color: #d8deea;
}

.bg_while .home-hero-subtitle {
    color: #6b7688;
}

.bg_while .home-category-card,
.bg_while .home-category-sidebar,
.bg_while .home-category-nav {
    border-color: #d8deea;
    background-color: #ffffff;
}

.bg_while .home-category-heading,
.bg_while .home-category-title,
.bg_while .home-category-count,
.bg_while .home-category-badge,
.bg_while .home-posts-empty,
.bg_while .home-empty {
    color: #7a8597;
}

.bg_while .home-category-link,
.bg_while .home-category-button,
.bg_while .home-category-item > a,
.bg_while .home-category-item > button {
    color: #4b5565;
}

.bg_while .home-category-link:hover,
.bg_while .home-category-button:hover,
.bg_while .home-category-item > a:hover,
.bg_while .home-category-item > button:hover {
    color: #1f2937;
    border-color: #d8deea;
    background-color: #f8faff;
}

.bg_while .home-category-link.is-active,
.bg_while .home-category-link.active,
.bg_while .home-category-button.is-active,
.bg_while .home-category-button.active,
.bg_while .home-category-item.is-active > a,
.bg_while .home-category-item.active > a,
.bg_while .home-category-item.is-active > button,
.bg_while .home-category-item.active > button {
    color: #1f2937;
    border-color: #9cb1ea;
    background-color: #eef2ff;
    box-shadow: inset 0 0 0 1px rgba(111, 142, 219, 0.12);
}

.bg_while .home-posts-empty,
.bg_while .home-empty {
    border-color: #d8deea;
    background-color: #ffffff;
}

.bg_while .home-year-title p,
.bg_while .home-post-name {
    color: #1f2937;
}

.bg_while .home-post-item {
    border-color: #d8deea;
}

.bg_while .home-post-link:hover .home-post-item {
    border-color: #b8c4db;
}

.bg_while .home-post-time {
    color: #7a8597;
}

.bg_while .category-group-count,
.bg_while .category-branch-separator,
.bg_while .category-branch-count {
    color: #7a8597;
}

.bg_while .category-tree {
    border-left-color: #d8deea;
}

.bg_while .category-branch-link {
    color: #50627e;
}

.bg_while .category-group-link {
    color: #1f2937;
}

.bg_while .category-branch-node {
    color: #6f8edb;
}

.bg_while hr {
    border-color: #d8deea;
}

.bg_while .jing {
    color: #6f8edb;
}

.bg_while .logot .logo_1,
.bg_while .logot .logo_2,
.bg_while .logot .logo_3 {
    color: inherit;
}

.bg_while .titlex {
    color: #1f2937;
}

.bg_while .list {
    color: #4b5565;
}

.bg_while .posttime {
    color: #7a8597;
}

.bg_while .postname {
    color: #1f2937;
}

.bg_while .flink,
.bg_while .ba {
    color: #4b5565;
}

.bg_while .flink:hover,
.bg_while .ba:hover {
    color: #1f2937;
}

.bg_while .home-year-line {
    background-color: #6f8edb;
}

.bg_while .home-hero-title {
    color: #1f2937;
}

.bg_while .home-index {
    color: #4b5565;
}

.bg_while .category-post-list .postname,
.bg_while .category-post-list .posttime {
    color: inherit;
}

.bg_while .category-post-list .posttime {
    color: #7a8597;
}

.bg_while .category-post-list .postname {
    color: #1f2937;
}

.bg_while .home-hero,
.bg_while .categories-page {
    color: #4b5565;
}
.categories-page {
    padding-bottom: 10px;
}

.category-group {
    margin-top: 30px;
}

.category-group:first-child {
    margin-top: 0;
}

.category-group-link {
    font-size: inherit;
}

.category-group-count {
    color: #8f9bb3;
    font-size: 18px;
}

.category-tree {
    margin-left: 18px;
    padding-left: 18px;
    border-left: 1px solid #58606b;
}

.category-branch {
    margin-top: 18px;
}

.category-branch:first-child {
    margin-top: 0;
}

.category-branch-title {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    font-size: 18px;
}

.category-branch-node {
    color: #6d9ee7;
    margin-right: 8px;
}

.category-branch-link {
    font-size: inherit;
    color: #9fc5ff;
}

.category-branch-separator {
    margin: 0 8px;
    color: #8f9bb3;
}

.category-branch-count {
    margin-left: 6px;
    color: #8f9bb3;
    font-size: 16px;
}

.category-branch-posts {
    margin-left: 20px;
}

.category-post-list {
    padding-left: 12px;
}

.category-post-list .postname,
.category-post-list .posttime {
    font-size: 16px;
}

.home-layout .home-year-title,
.home-layout-shell .home-year-title {
    margin-top: 0;
}

.home-layout .home-year-title + .home-post-link,
.home-layout-shell .home-year-title + .home-post-link {
    margin-top: 4px;
}

@media (max-width: 1100px) {
    .home-layout,
    .home-layout-shell {
        grid-template-columns: minmax(0, 190px) minmax(0, 1fr);
        gap: 24px;
    }

    .home-category-card,
    .home-category-sidebar,
    .home-category-nav {
        padding: 16px;
    }
}

@media (max-width: 860px) {
    .home-layout,
    .home-layout-shell {
        grid-template-columns: 1fr;
        gap: 22px;
    }

    .home-layout-sidebar,
    .home-category-sidebar,
    .home-category-nav {
        position: static;
    }

    .home-category-list,
    .home-category-items {
        flex-direction: row;
        flex-wrap: wrap;
    }

    .home-category-link,
    .home-category-button,
    .home-category-item > a,
    .home-category-item > button {
        width: auto;
        min-width: 0;
    }
}

@media (max-width: 640px) {
    .home-hero {
        padding-top: 44px;
    }

    .home-hero-title {
        font-size: 34px;
    }

    .home-layout,
    .home-layout-shell {
        gap: 18px;
    }

    .home-category-card,
    .home-category-sidebar,
    .home-category-nav,
    .home-posts-empty,
    .home-empty {
        padding: 14px;
        border-radius: 14px;
    }

    .home-category-link,
    .home-category-button,
    .home-category-item > a,
    .home-category-item > button {
        width: 100%;
    }

    .home-post-item {
        padding-top: 14px;
        padding-bottom: 14px;
    }

    .home-post-name {
        max-width: 100%;
        float: none;
        margin-bottom: 6px;
    }

    .home-post-time {
        float: none;
        display: block;
    }
}
