.logodiv {
    text-align: center;
}

.titlex {
    font-size: 30px;
    font-weight: bold;
    margin-top: 30px;
}

.list {
    font-size: 17px;
    padding-left: 25px;
    padding-right: 25px;
    height: 30px;
    cursor: pointer;
}

.postname {
    float: left;
}

.posttime {
    float: right;
}

.logopng {
    width: 150px;
}

.breadcrumb {
    padding: 8px 15px;
    list-style: none;
    background-color: initial;
    border-radius: 0px;
    text-align: center;
}


.jing {
    color: #1E90FF;
}

.logot {
    font-weight: bold;
    font-size: 45px;
    margin-top: 10px;
    margin-bottom: -20px;
}

.logot .logo_1{
    color: #888888;
}

.logot .logo_2{
    color: #37dd2c;
}

.logot .logo_3{
    color: #be8355;
}
.words {
    padding-top: 16px;
    font-size: 20px;
}
.navd {
    padding-top: 14px;
}

.headt {
    border-bottom: 1px solid #efefef;
    height: 50px;
}

.fh {
    top: 24px;
    position: absolute;
}

hr{
    border-color: #58606b;
}

.home-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 56px 0 18px;
}

.home-hero-avatar {
    width: 96px;
    height: 96px;
}

.home-hero .logopng {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 1px solid #232938;
    padding: 6px;
    background-color: #151922;
}

.home-hero-copy {
    max-width: 640px;
}

.home-hero-title {
    margin: 0;
    font-size: 42px;
    line-height: 1.2;
    letter-spacing: 0.04em;
}

.home-hero-subtitle {
    margin: 14px 0 0;
    padding-top: 0;
    font-size: 16px;
    line-height: 1.9;
    color: #99a3b8;
}

.home-hero-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-top: 22px;
}

.home-hero-action {
    display: inline-block;
    padding: 9px 16px;
    border: 1px solid #232938;
    border-radius: 999px;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: #c8d1e3;
    background-color: #151922;
}

.home-hero-action:hover {
    color: #ffffff;
    border-color: #8aa4ff;
    background-color: #1a2030;
    transform: translateY(-1px);
}

.home-index {
    padding-bottom: 24px;
}

.home-year-title {
    margin-top: 44px;
    margin-bottom: 16px;
    font-size: 26px;
}

.home-year-title:first-child {
    margin-top: 0;
}

.home-year-title p {
    display: flex;
    align-items: center;
    margin: 0;
    color: #eef2ff;
}

.home-year-line {
    display: inline-block;
    width: 38px;
    height: 1px;
    margin-right: 14px;
    background-color: #8aa4ff;
}

.home-post-link {
    display: block;
}

.home-post-item {
    height: auto;
    min-height: 0;
    padding: 16px 2px;
    border-bottom: 1px solid #232938;
}

.home-post-link:hover .home-post-item {
    border-color: #323a4c;
    transform: translateX(2px);
}

.home-post-name {
    max-width: calc(100% - 120px);
    font-size: 17px;
    color: #e7ebf5;
}

.home-post-time {
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #778198;
}

.bg_while .home-hero .logopng {
    background-color: #ffffff;
    border-color: #d8deea;
}

.bg_while .home-hero-subtitle {
    color: #6b7688;
}

.bg_while .home-hero-action {
    color: #3e4a5b;
    border-color: #d8deea;
    background-color: #ffffff;
}

.bg_while .home-hero-action:hover {
    color: #1c2532;
    border-color: #8aa4ff;
    background-color: #eef2ff;
}

.bg_while .home-year-title p,
.bg_while .home-post-name {
    color: #1f2937;
}

.bg_while .home-post-item {
    border-color: #d8deea;
}

.bg_while .home-post-link:hover .home-post-item {
    border-color: #b8c4db;
}

.bg_while .home-post-time {
    color: #7a8597;
}

.bg_while .category-group-count,
.bg_while .category-branch-separator,
.bg_while .category-branch-count {
    color: #7a8597;
}

.bg_while .category-tree {
    border-left-color: #d8deea;
}

.bg_while .category-branch-link {
    color: #50627e;
}

.bg_while .category-group-link {
    color: #1f2937;
}

.bg_while .category-branch-node {
    color: #6f8edb;
}

.bg_while hr {
    border-color: #d8deea;
}

.bg_while .jing {
    color: #6f8edb;
}

.bg_while .logot .logo_1,
.bg_while .logot .logo_2,
.bg_while .logot .logo_3 {
    color: inherit;
}

.bg_while .titlex {
    color: #1f2937;
}

.bg_while .list {
    color: #4b5565;
}

.bg_while .posttime {
    color: #7a8597;
}

.bg_while .postname {
    color: #1f2937;
}

.bg_while .flink,
.bg_while .ba {
    color: #4b5565;
}

.bg_while .flink:hover,
.bg_while .ba:hover {
    color: #1f2937;
}

.bg_while .home-year-line {
    background-color: #6f8edb;
}

.bg_while .home-hero-title {
    color: #1f2937;
}

.bg_while .home-index {
    color: #4b5565;
}

.bg_while .category-post-list .postname,
.bg_while .category-post-list .posttime {
    color: inherit;
}

.bg_while .category-post-list .posttime {
    color: #7a8597;
}

.bg_while .category-post-list .postname {
    color: #1f2937;
}

.bg_while .home-hero,
.bg_while .categories-page {
    color: #4b5565;
}
.categories-page {
    padding-bottom: 10px;
}

.category-group {
    margin-top: 30px;
}

.category-group:first-child {
    margin-top: 0;
}

.category-group-link {
    font-size: inherit;
}

.category-group-count {
    color: #8f9bb3;
    font-size: 18px;
}

.category-tree {
    margin-left: 18px;
    padding-left: 18px;
    border-left: 1px solid #58606b;
}

.category-branch {
    margin-top: 18px;
}

.category-branch:first-child {
    margin-top: 0;
}

.category-branch-title {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    font-size: 18px;
}

.category-branch-node {
    color: #6d9ee7;
    margin-right: 8px;
}

.category-branch-link {
    font-size: inherit;
    color: #9fc5ff;
}

.category-branch-separator {
    margin: 0 8px;
    color: #8f9bb3;
}

.category-branch-count {
    margin-left: 6px;
    color: #8f9bb3;
    font-size: 16px;
}

.category-branch-posts {
    margin-left: 20px;
}

.category-post-list {
    padding-left: 12px;
}

.category-post-list .postname,
.category-post-list .posttime {
    font-size: 16px;
}
