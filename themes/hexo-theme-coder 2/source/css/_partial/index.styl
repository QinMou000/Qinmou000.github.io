.logodiv {
    text-align: center;
}

.titlex {
    font-size: 30px;
    font-weight: bold;
    margin-top: 30px;
}

.list {
    font-size: 17px;
    padding-left: 25px;
    padding-right: 25px;
    height: 30px;
    cursor: pointer;
}

.postname {
    float: left;
}

.posttime {
    float: right;
}

.logopng {
    width: 150px;
}

.breadcrumb {
    padding: 8px 15px;
    list-style: none;
    background-color: initial;
    border-radius: 0px;
    text-align: center;
}


.jing {
    color: #1E90FF;
}

.logot {
    font-weight: bold;
    font-size: 45px;
    margin-top: 10px;
    margin-bottom: -20px;
}

.logot .logo_1{
    color: #888888;
}

.logot .logo_2{
    color: #37dd2c;
}

.logot .logo_3{
    color: #be8355;
}
.words {
    padding-top: 16px;
    font-size: 20px;
}
.navd {
    padding-top: 14px;
}

.headt {
    border-bottom: 1px solid #efefef;
    height: 50px;
}

.fh {
    top: 24px;
    position: absolute;
}

hr{
    border-color: #58606b;
}

.categories-page {
    padding-bottom: 10px;
}

.category-group {
    margin-top: 30px;
}

.category-group:first-child {
    margin-top: 0;
}

.category-group-link {
    font-size: inherit;
}

.category-group-count {
    color: #8f9bb3;
    font-size: 18px;
}

.category-tree {
    margin-left: 18px;
    padding-left: 18px;
    border-left: 1px solid #58606b;
}

.category-branch {
    margin-top: 18px;
}

.category-branch:first-child {
    margin-top: 0;
}

.category-branch-title {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    font-size: 18px;
}

.category-branch-node {
    color: #6d9ee7;
    margin-right: 8px;
}

.category-branch-link {
    font-size: inherit;
    color: #9fc5ff;
}

.category-branch-separator {
    margin: 0 8px;
    color: #8f9bb3;
}

.category-branch-count {
    margin-left: 6px;
    color: #8f9bb3;
    font-size: 16px;
}

.category-branch-posts {
    margin-left: 20px;
}

.category-post-list {
    padding-left: 12px;
}

.category-post-list .postname,
.category-post-list .posttime {
    font-size: 16px;
}
