.logodiv {
    text-align: center;
}

.titlex {
    font-size: 30px;
    font-weight: bold;
    margin-top: 30px;
}

.list {
    font-size: 17px;
    padding-left: 25px;
    padding-right: 25px;
    height: 30px;
    cursor: pointer;
}

.postname {
    float: left;
}

.posttime {
    float: right;
}

.logopng {
    width: 150px;
}

.breadcrumb {
    padding: 8px 15px;
    list-style: none;
    background-color: initial;
    border-radius: 0px;
    text-align: center;
}


.jing {
    color: #1E90FF;
}

.logot {
    font-weight: bold;
    font-size: 45px;
    margin-top: 10px;
    margin-bottom: -20px;
}

.logot .logo_1{
    color: #888888;
}

.logot .logo_2{
    color: #37dd2c;
}

.logot .logo_3{
    color: #be8355;
}
.words {
    padding-top: 16px;
    font-size: 20px;
}
.navd {
    padding-top: 14px;
}

.headt {
    border-bottom: 1px solid #efefef;
    height: 50px;
}

.fh {
    top: 24px;
    position: absolute;
}

hr{
    border-color: #666;
}

.home-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 56px 0 18px;
}

.home-hero-avatar {
    width: 96px;
    height: 96px;
}

.home-hero .logopng {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 1px solid #444;
    padding: 6px;
    background-color: #111;
}

.home-hero-copy {
    max-width: 640px;
}

.home-hero-title {
    margin: 0;
    font-size: 42px;
    line-height: 1.2;
    letter-spacing: 0.04em;
}

.home-hero-subtitle {
    margin: 14px 0 0;
    padding-top: 0;
    font-size: 16px;
    line-height: 1.9;
    color: #bbb;
}

.home-index {
    padding-bottom: 24px;
}

.home-layout,
.home-layout-shell {
    display: grid;
    grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
}

.home-layout-sidebar {
    position: sticky;
    top: 18px;
    min-width: 0;
}

.home-layout-content,
.home-posts,
.home-posts-panel {
    min-width: 0;
}

.home-load-more-shell {
    padding-top: 26px;
    text-align: center;
}

.home-load-more {
    min-width: 150px;
    padding: 11px 22px;
    border: 1px solid #555;
    border-radius: 999px;
    background-color: #111;
    color: #e7ebf5;
    font: inherit;
    cursor: pointer;
    transition: color 0.25s ease, border-color 0.25s ease, background-color 0.25s ease, transform 0.25s ease;
}

.home-load-more:hover {
    border-color: #888;
    background-color: #1a2030;
    transform: translateY(-1px);
}

.home-load-more[hidden] {
    display: none;
}

.home-result-summary {
    margin: 12px 0 0;
    color: #8f9bb3;
    font-size: 12px;
}

.home-posts-empty,
.home-empty {
    padding: 40px 24px;
    border: 1px dashed #555;
    border-radius: 18px;
    color: #8f9bb3;
    background-color: rgba(21, 25, 34, 0.72);
    text-align: center;
}

.home-posts-empty p,
.home-empty p {
    margin: 0;
}

.home-year-title {
    margin-top: 44px;
    margin-bottom: 16px;
    font-size: 26px;
}

.home-year-title:first-child {
    margin-top: 0;
}

.home-year-title p {
    display: flex;
    align-items: center;
    margin: 0;
    color: #fff;
}

.home-year-line {
    display: inline-block;
    width: 38px;
    height: 1px;
    margin-right: 14px;
    background-color: #fff;
}

.home-post-link {
    display: block;
}

.home-post-item {
    height: auto;
    min-height: 0;
    padding: 16px 2px;
    border-bottom: 1px solid #444;
}

.home-post-link:hover .home-post-item {
    border-color: #555;
    transform: translateX(2px);
}

.home-post-name {
    max-width: calc(100% - 120px);
    font-size: 17px;
    color: #e7ebf5;
}

.home-post-time {
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #999;
}

.bg_while .home-hero .logopng {
    background-color: #ffffff;
    border-color: #ddd;
}

.bg_while .home-hero-subtitle {
    color: #6b7688;
}

.bg_while .home-posts-empty,
.bg_while .home-empty {
    color: #7a8597;
}

.bg_while .home-posts-empty,
.bg_while .home-empty {
    border-color: #ddd;
    background-color: #ffffff;
}

.bg_while .home-year-title p,
.bg_while .home-post-name {
    color: #000;
}

.bg_while .home-post-item {
    border-color: #ddd;
}

.bg_while .home-post-link:hover .home-post-item {
    border-color: #b8c4db;
}

.bg_while .home-post-time {
    color: #7a8597;
}

.bg_while .home-load-more {
    border-color: #ccd2dc;
    background-color: #fff;
    color: #283345;
}

.bg_while .home-load-more:hover {
    border-color: #9aa6b8;
    background-color: #f4f6fa;
}

.bg_while .home-result-summary {
    color: #7a8597;
}

.bg_while hr {
    border-color: #ddd;
}

.bg_while .jing {
    color: #000;
}

.bg_while .logot .logo_1,
.bg_while .logot .logo_2,
.bg_while .logot .logo_3 {
    color: inherit;
}

.bg_while .titlex {
    color: #000;
}

.bg_while .list {
    color: #4b5565;
}

.bg_while .posttime {
    color: #7a8597;
}

.bg_while .postname {
    color: #000;
}

.bg_while .flink,
.bg_while .ba {
    color: #4b5565;
}

.bg_while .flink:hover,
.bg_while .ba:hover {
    color: #000;
}

.bg_while .home-year-line {
    background-color: #000;
}

.bg_while .home-hero-title {
    color: #000;
}

.bg_while .home-index {
    color: #4b5565;
}

.bg_while .home-hero,
.bg_while .categories-page {
    color: #4b5565;
}

.bg_while .categories-eyebrow,
.bg_while .categories-description,
.bg_while .category-card-count,
.bg_while .category-card-post-date {
    color: #7a8597;
}

.bg_while .categories-title,
.bg_while .category-card-title,
.bg_while .category-card-post-title {
    color: #111827;
}

.bg_while .category-card {
    border-color: #d8dee8;
    background-color: #fff;
    box-shadow: 0 18px 45px rgba(31, 41, 55, 0.08);
}

.bg_while .category-card:hover {
    border-color: #aeb9cb;
}

.bg_while .category-card-child {
    border-color: #d8dee8;
    background-color: #f5f7fb;
    color: #526078;
}

.bg_while .category-card-child:hover {
    border-color: #aeb9cb;
    background-color: #edf1f7;
    color: #111827;
}

.bg_while .category-card-post {
    border-bottom-color: #e6e9ef;
}

.bg_while .category-card-post:hover .category-card-post-title,
.bg_while .category-card-more {
    color: #111827;
}

.bg_while .category-card-more {
    border-top-color: #d8dee8;
}

.categories-page {
    padding-bottom: 36px;
}

.categories-header {
    max-width: 620px;
    margin-bottom: 32px;
}

.categories-eyebrow {
    margin: 0 0 10px;
    color: #8f9bb3;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
}

.categories-title {
    margin: 0;
    color: #fff;
    font-size: 34px;
    line-height: 1.25;
}

.categories-description {
    margin: 12px 0 0;
    color: #8f9bb3;
    font-size: 15px;
    line-height: 1.8;
}

.categories-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
    align-items: stretch;
}

.category-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: 22px;
    border: 1px solid #333a49;
    border-radius: 18px;
    background-color: #10131a;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.22);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
}

.category-card:hover {
    border-color: #58657a;
    box-shadow: 0 22px 55px rgba(0, 0, 0, 0.3);
    transform: translateY(-3px);
}

.category-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
}

.category-card-title {
    display: flex;
    min-width: 0;
    align-items: baseline;
    gap: 8px;
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    line-height: 1.35;
}

.category-card-mark {
    color: #8aa4ff;
}

.category-card-count {
    flex-shrink: 0;
    color: #8f9bb3;
    font-size: 12px;
    letter-spacing: 0.06em;
}

.category-card-children {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
}

.category-card-child {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 10px;
    border: 1px solid #343c4b;
    border-radius: 999px;
    background-color: #171c26;
    color: #aeb8ca;
    font-size: 12px;
}

.category-card-child:hover {
    border-color: #58657a;
    background-color: #1d2431;
    color: #fff;
}

.category-card-child span {
    color: #7f8ba1;
    font-size: 11px;
}

.category-card-posts {
    flex: 1;
    margin-top: 18px;
}

.category-card-post {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    padding: 10px 0;
    border-bottom: 1px solid #282f3b;
}

.category-card-post-title {
    min-width: 0;
    overflow: hidden;
    color: #d8deea;
    font-size: 14px;
    line-height: 1.55;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.category-card-post-date {
    flex-shrink: 0;
    color: #77839a;
    font-size: 11px;
    letter-spacing: 0.05em;
}

.category-card-post:hover .category-card-post-title {
    color: #fff;
}

.category-card-more {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid #343c4b;
    color: #d8deea;
    font-size: 13px;
    font-weight: 600;
}

.category-card-more:hover {
    color: #fff;
}

.category-card-more span {
    transition: transform 0.25s ease;
}

.category-card-more:hover span {
    transform: translateX(4px);
}

.home-layout .home-year-title,
.home-layout-shell .home-year-title {
    margin-top: 0;
}

.home-layout .home-year-title + .home-post-link,
.home-layout-shell .home-year-title + .home-post-link {
    margin-top: 4px;
}

@media (max-width: 1100px) {
    .home-layout,
    .home-layout-shell {
        grid-template-columns: minmax(0, 190px) minmax(0, 1fr);
        gap: 24px;
    }

    .categories-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 860px) {
    .home-layout,
    .home-layout-shell {
        grid-template-columns: 1fr;
        gap: 22px;
    }

    .home-layout-sidebar {
        position: static;
    }
}

@media (max-width: 640px) {
    .home-hero {
        padding-top: 44px;
    }

    .home-hero-title {
        font-size: 34px;
    }

    .home-layout,
    .home-layout-shell {
        gap: 18px;
    }

    .home-posts-empty,
    .home-empty {
        padding: 14px;
        border-radius: 14px;
    }

    .home-post-item {
        padding-top: 14px;
        padding-bottom: 14px;
    }

    .home-post-name {
        max-width: 100%;
        float: none;
        margin-bottom: 6px;
    }

    .home-post-time {
        float: none;
        display: block;
    }

    .categories-header {
        margin-bottom: 24px;
    }

    .categories-title {
        font-size: 28px;
    }

    .categories-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }

    .category-card {
        padding: 18px;
        border-radius: 15px;
    }

    .category-card-title {
        font-size: 20px;
    }
}
