.post-container {
    padding-top: 28px;
}

// 目录脱离正常文档流，悬浮在视口右侧空白区，不挤占文章宽度
.post-toc {
    position: fixed;
    top: 80px;
    right: 24px;
    width: 200px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    opacity: 0;
    transition: opacity 0.25s ease;
    z-index: 10;
    pointer-events: none;
}

.post-toc:hover {
    opacity: 1;
    pointer-events: auto;
}

// 鼠标移到右侧边缘也能唤出目录，避免完全透明时无法触发 hover
.post-page:hover .post-toc {
    opacity: 0.35;
    pointer-events: auto;
}

.post-page:hover .post-toc:hover {
    opacity: 1;
}

.post-toc-title {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.post-toc-nav {
    border-left: 2px solid #444;
    padding-left: 14px;
}

.post-toc-nav a {
    display: block;
    font-size: 13px;
    color: #aaa;
    text-decoration: none;
    padding: 5px 0;
    transition: color 0.2s;
    line-height: 1.4;
}

.post-toc-nav a:hover {
    color: #fff;
}

.post-toc-nav a.active {
    color: #fff;
    font-weight: 500;
}

.post-toc-nav .toc-h2 {
    padding-left: 0;
}

.post-toc-nav .toc-h3 {
    padding-left: 12px;
}

.post-toc-nav .toc-h4 {
    padding-left: 24px;
}

.post-toc-nav .toc-h5 {
    padding-left: 36px;
}

.post-toc-nav .toc-h6 {
    padding-left: 48px;
}

.post-article {
    width: 100%;
    min-width: 0;
}

.bg_while .post-toc-title {
    color: #111;
}

.bg_while .post-toc-nav {
    border-left-color: #ddd;
}

.bg_while .post-toc-nav a {
    color: #555;
}

.bg_while .post-toc-nav a:hover,
.bg_while .post-toc-nav a.active {
    color: #000;
}

.post-page {
    padding-bottom: 30px;
}

.post-hero {
    padding: 16px 0 12px;
}

.post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 18px;
    color: #888;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.post-meta-separator {
    color: #555;
}

.post-hero-title {
    text-align: center;
    margin-bottom: 16px;
}

.post-hero-title p {
    margin: 0;
    font-size: 38px;
    line-height: 1.35;
    color: #fff;
}

.post-hero-divider {
    margin: 0;
    border-color: #444;
}

.post-article {
    padding-top: 28px;
}

.post-article-body,
.post-content {
    width: 100%;
    height: 100%;
    margin: auto;
}

.post-content p {
    font-size: 17px;
    font-weight: 400;
}

.post-content li {
    font-size: 16px;
    font-weight: 400;
}

.post-content a {
    font-size: inherit;
}

.post-comments-divider {
    margin-top: 34px;
    margin-bottom: 24px;
    border-color: #444;
}

.post-comments {
    padding-bottom: 10px;
}

.posts .fhr {
    margin-top: 20px;
}

.posts .highlight
    .gutter
        .hljs
            border-top-left-radius: 5px;
            border-bottom-left-radius: 5px;

.posts .highlight
    .code
        .hljs
            border-top-right-radius: 5px;
            border-bottom-right-radius: 5px;

.bg_while .post-meta {
    color: #666;
}

.bg_while .post-meta-separator {
    color: #999;
}

.bg_while .post-hero-title p {
    color: #000;
}

.bg_while .post-hero-divider,
.bg_while .post-comments-divider {
    border-color: #ddd;
}

.bg_while .post-content p,
.bg_while .post-content li {
    color: #111;
}

.bg_while .post-comments {
    color: #111;
}

// 手机端适配
@media screen and (max-width: 768px) {
    .post-container {
        padding-top: 20px;
    }

    // 手机端隐藏目录
    .post-toc {
        display: none;
    }

    .post-article {
        width: 100%;
    }

    .post-hero-title p {
        font-size: 26px;
    }

    .post-meta {
        font-size: 12px;
        gap: 8px;
    }

    .post-content p {
        font-size: 16px;
    }

    .post-content li {
        font-size: 15px;
    }

    .post-comments-divider {
        margin-top: 28px;
        margin-bottom: 20px;
    }
}