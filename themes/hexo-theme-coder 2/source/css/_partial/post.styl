.post-container {
    display: flex;
    gap: 40px;
    padding-top: 28px;
}

.post-toc {
    flex-shrink: 0;
    width: 200px;
    position: sticky;
    top: 80px;
    align-self: flex-start;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
}

.post-toc-title {
    font-size: 14px;
    font-weight: 600;
    color: #8f9bb3;
    margin-bottom: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.post-toc-nav {
    border-left: 2px solid #232938;
    padding-left: 14px;
}

.post-toc-nav a {
    display: block;
    font-size: 13px;
    color: #6a7a9a;
    text-decoration: none;
    padding: 5px 0;
    transition: color 0.2s;
    line-height: 1.4;
}

.post-toc-nav a:hover {
    color: #8aa4ff;
}

.post-toc-nav a.active {
    color: #8aa4ff;
    font-weight: 500;
}

.post-toc-nav .toc-h2 {
    padding-left: 0;
}

.post-toc-nav .toc-h3 {
    padding-left: 12px;
}

.post-toc-nav .toc-h4 {
    padding-left: 24px;
}

.post-toc-nav .toc-h5 {
    padding-left: 36px;
}

.post-toc-nav .toc-h6 {
    padding-left: 48px;
}

.post-article {
    flex: 1;
    min-width: 0;
}

.bg_while .post-toc-title {
    color: #7a8597;
}

.bg_while .post-toc-nav {
    border-left-color: #d8deea;
}

.bg_while .post-toc-nav a {
    color: #6a737d;
}

.bg_while .post-toc-nav a:hover,
.bg_while .post-toc-nav a.active {
    color: #5673d6;
}

.post-page {
    padding-bottom: 30px;
}

.post-hero {
    padding: 16px 0 12px;
}

.post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 18px;
    color: #8f9bb3;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.post-meta-separator {
    color: #4d5768;
}

.post-hero-title {
    text-align: center;
    margin-bottom: 16px;
}

.post-hero-title p {
    margin: 0;
    font-size: 38px;
    line-height: 1.35;
    color: #eef2ff;
}

.post-hero-divider {
    margin: 0;
    border-color: #232938;
}

.post-article {
    padding-top: 28px;
}

.post-article-body,
.post-content {
    width: 100%;
    height: 100%;
    margin: auto;
}

.post-content p {
    font-size: 17px;
    font-weight: 400;
}

.post-content li {
    font-size: 16px;
    font-weight: 400;
}

.post-content a {
    font-size: inherit;
}

.post-comments-divider {
    margin-top: 34px;
    margin-bottom: 24px;
    border-color: #232938;
}

.post-comments {
    padding-bottom: 10px;
}

.posts .fhr {
    margin-top: 20px;
}

.posts .highlight
    .gutter
        .hljs
            border-top-left-radius: 5px;
            border-bottom-left-radius: 5px;

.posts .highlight
    .code
        .hljs
            border-top-right-radius: 5px;
            border-bottom-right-radius: 5px;

.bg_while .post-meta {
    color: #7a8597;
}

.bg_while .post-meta-separator {
    color: #b3bfd3;
}

.bg_while .post-hero-title p {
    color: #1f2937;
}

.bg_while .post-hero-divider,
.bg_while .post-comments-divider {
    border-color: #d8deea;
}

.bg_while .post-content p,
.bg_while .post-content li {
    color: #4b5565;
}

.bg_while .post-comments {
    color: #4b5565;
}